# ================================================================
# exhibition-asset 環境変数
# このファイルをコピーして .env を作成し、実際の値を記入してください
# ================================================================

# ──────────────────────────────────────────────
# kintone (Relavaと同じサブドメイン・管理者アカウントを使用)
# ──────────────────────────────────────────────
KINTONE_SUBDOMAIN=
KINTONE_ADMIN_USER=
KINTONE_ADMIN_PASSWORD=

# ──────────────────────────────────────────────
# n8n (Relavaと同じインスタンスを使用)
# ──────────────────────────────────────────────
N8N_INSTANCE_URL=
N8N_API_KEY=

# ──────────────────────────────────────────────
# kintoneアプリID（npm run setup:apps 実行後に自動で書き込まれます）
# ──────────────────────────────────────────────
KINTONE_APP_ID_ACCOUNT=
KINTONE_APP_ID_OPPORTUNITY=
KINTONE_APP_ID_LEAD=

# ──────────────────────────────────────────────
# レコード操作用APIトークン（各アプリの管理画面で発行して記入 - phase 2以降で使用）
# ──────────────────────────────────────────────
KINTONE_API_TOKEN_ACCOUNT=
KINTONE_API_TOKEN_OPPORTUNITY=
KINTONE_API_TOKEN_LEAD=
