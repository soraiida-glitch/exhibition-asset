# ================================================================
# exhibition-asset 環境変数
# このファイルをコピーして .env を作成し、実際の値を記入してください
# ================================================================

# ──────────────────────────────────────────────
# kintone (Relavaと同じサブドメイン・管理者アカウントを使用)
# ──────────────────────────────────────────────
KINTONE_SUBDOMAIN=
KINTONE_ADMIN_USER=
KINTONE_ADMIN_PASSWORD=

# ──────────────────────────────────────────────
# n8n (Relavaと同じインスタンスを使用)
# ──────────────────────────────────────────────
N8N_INSTANCE_URL=
N8N_API_KEY=
# npm run setup:agent 実行後に自動で生成・書き込まれます
N8N_WEBHOOK_SECRET=
N8N_KINTONE_AGENT_WEBHOOK_URL=
# npm run setup:meishi 実行後に自動で書き込まれます
N8N_MEISHI_WEBHOOK_URL=
# npm run setup:contact-form 実行後に自動で生成・書き込まれます
N8N_CONTACT_FORM_SECRET=
N8N_CONTACT_FORM_WEBHOOK_URL=
# npm run setup:sync 実行後に自動で書き込まれます
N8N_SYNC_WEBHOOK_URL=
# npm run setup:closing-advice 実行後に自動で書き込まれます
N8N_CLOSING_ADVICE_WEBHOOK_URL=
# npm run setup:roleplay 実行後に自動で書き込まれます
N8N_ROLEPLAY_START_WEBHOOK_URL=
N8N_ROLEPLAY_CHAT_WEBHOOK_URL=
N8N_ROLEPLAY_FEEDBACK_WEBHOOK_URL=
# npm run setup:audio 実行後に自動で書き込まれます
N8N_TRANSCRIBE_WEBHOOK_URL=
N8N_TTS_WEBHOOK_URL=

# ──────────────────────────────────────────────
# OpenAI (秘書AIエージェントのGPT-4o呼び出しに使用)
# ──────────────────────────────────────────────
OPENAI_API_KEY=

# ──────────────────────────────────────────────
# Pinecone (RAG基盤 - Relavaと同じアカウント/インデックス、namespaceで分離)
# ──────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_HOST=
PINECONE_NAMESPACE=exhibition-kintone

# ──────────────────────────────────────────────
# kintoneアプリID（npm run setup:apps 実行後に自動で書き込まれます）
# ──────────────────────────────────────────────
KINTONE_APP_ID_ACCOUNT=
KINTONE_APP_ID_OPPORTUNITY=
KINTONE_APP_ID_LEAD=
KINTONE_APP_ID_CONVERSATION_LOG=
KINTONE_APP_ID_DAILY_ADVICE=
KINTONE_APP_ID_ROLEPLAY_SESSION=

# ──────────────────────────────────────────────
# レコード操作用APIトークン（各アプリの管理画面で発行して記入 - phase 2以降で使用）
# ──────────────────────────────────────────────
KINTONE_API_TOKEN_ACCOUNT=
KINTONE_API_TOKEN_OPPORTUNITY=
KINTONE_API_TOKEN_LEAD=
KINTONE_API_TOKEN_CONVERSATION_LOG=
KINTONE_API_TOKEN_DAILY_ADVICE=
KINTONE_API_TOKEN_ROLEPLAY_SESSION=
